	local normalSpeeds = {8, 10, 12, 14, 16}
	local Tracker = {
		Kind = "active",
		Running = true,
		Hunting = false,
		States = setmetatable({}, {__mode = "k"}),
		Connections = {},
	}

	local function remember(connection)
		table.insert(Tracker.Connections, connection)
	end

	local function near(first, second)
		return math.abs(first - second) <= epsilon
	end

	local function learn(state, speed)
		if not state.BaseSpeed then
			for _, candidate in ipairs(normalSpeeds) do
				if near(speed, candidate) then
					state.BaseSpeed = candidate
					state.SprintSpeed = candidate * 1.6
					return
				end
			end
		elseif near(speed, state.BaseSpeed * 1.6) then
			state.SprintSpeed = speed
			state.SprintObserved = true
		end
	end

	local function rawPoint(state)
		local speed = state.Humanoid and tonumber(state.Humanoid.WalkSpeed)
		if not speed then return nil end
		return {s = speed}
	end

	local function append(state, point)
		table.insert(state.Samples, point)
		while #state.Samples > 40 do table.remove(state.Samples, 1) end
	end

	local function send(state, completed)
		if not state.BeforeLOS or not state.BaseSpeed then return end
		Traffic("PlayerLOSSpeed", {
			Player = state.Player,
			BaseSpeed = state.BaseSpeed,
			SprintSpeed = state.SprintSpeed or state.BaseSpeed * 1.6,
			beforeLOS = state.BeforeLOS,
			afterLOS = state.AfterLOS,
			Duration = math.max(0, clock() - state.StartedAt),
			Hunting = Tracker.Hunting,
			completed = completed == true,
		}):SendTo("LOSSpeed")
	end

	local function clearTrial(state)
		state.InLOS = false
		state.BeforeLOS, state.AfterLOS, state.StartedAt = nil, nil, nil
	end

	local function sample(state)
		local point = rawPoint(state)
		if not point then return end
		if not Tracker.Hunting then learn(state, point.s) end
		append(state, point)
		if not Tracker.Hunting or not state.InLOS or not state.BaseSpeed then return end
		if not state.BeforeLOS then
			state.BeforeLOS = table.clone(state.Samples)
			state.AfterLOS = {point}
			state.StartedAt = clock()
		else
			table.insert(state.AfterLOS, point)
		end
		send(state, false)
	end

	local function bindCharacter(state, character)
		state.Character = character
		state.Humanoid = character and character:FindFirstChildOfClass("Humanoid") or nil
		state.Samples = {}
		state.BaseSpeed, state.SprintSpeed, state.SprintObserved = nil, nil, false
		clearTrial(state)
		if not state.Humanoid then return end
		local initial = rawPoint(state)
		if initial then
			if not Tracker.Hunting then learn(state, initial.s) end
			append(state, initial)
		end
		remember(state.Humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
			if Tracker.Running and Tracker.States[state.Player] == state then sample(state) end
		end))
	end

	local function track(player)
		local state = {Player = player, Samples = {}, InLOS = false}
		Tracker.States[player] = state
		bindCharacter(state, player.Character)
		remember(player.CharacterAdded:Connect(function(character)
			bindCharacter(state, character)
		end))
	end

	for _, player in ipairs(Players:GetPlayers()) do track(player) end
	remember(Players.PlayerAdded:Connect(track))
	remember(Players.PlayerRemoving:Connect(function(player)
		Tracker.States[player] = nil
	end))

	Tracker.Disconnect = Traffic:Receive("PlayerSpeed", function(signal, payload)
		payload = type(payload) == "table" and payload or {}
		if signal == "HuntingState" then
			Tracker.Hunting = payload.Hunting == true
			for _, state in pairs(Tracker.States) do
				clearTrial(state)
				if not Tracker.Hunting then sample(state) end
			end
			return
		end
		if signal ~= "PlayerLineOfSight" or not Tracker.Hunting then return end
		local state = Tracker.States[payload.Player]
		if not state then return end
		if payload.LineOfSight == true then
			state.InLOS = true
			sample(state)
		elseif state.InLOS then
			local point = rawPoint(state)
			if point and state.BeforeLOS then
				append(state, point)
				table.insert(state.AfterLOS, point)
				send(state, true)
			end
			clearTrial(state)
		end
	end)

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		self.Disconnect()
		for _, connection in ipairs(self.Connections) do connection:Disconnect() end
		table.clear(self.Connections)
		table.clear(self.States)
	end

	return Tracker
end
]],
	["ghost/active-trackers/salt-hit.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "salt-hit requires Traffic")
	local Ghost = assert(dependencies.Ghost, "salt-hit requires Ghost")
	local SaltFolder = assert(dependencies.SaltFolder, "salt-hit requires SaltFolder")
	local World = dependencies.Workspace or workspace
	local RunService = assert(dependencies.RunService, "salt-hit requires RunService")
	local clock = dependencies.Clock or os.clock
	local Tracker = {
		Kind = "active",
		Running = true,
		Connections = {},
		Bound = setmetatable({}, {__mode = "k"}),
		Watched = setmetatable({}, {__mode = "k"}),
		PendingSpatial = setmetatable({}, {__mode = "k"}),
		Touched = setmetatable({}, {__mode = "k"}),
		Disturbed = setmetatable({}, {__mode = "k"}),
		CreatedAt = setmetatable({}, {__mode = "k"}),
		NextContactId = 0,
	}

	local function saltObject(part)
		local current = part
		while current and current.Parent ~= SaltFolder do
			current = current.Parent
		end
		return current or part
	end

	local function isDisturbed(salt)
		if salt:GetAttribute("Disturbed") == true then return true end
		local name = string.lower(salt.Name):gsub("[^%w]", "")
		return string.find(name, "disturbedsalt", 1, true) ~= nil
	end

	local function hasDisturbed(salt)
		if isDisturbed(salt) then return true end
		for _, object in ipairs(salt:GetDescendants()) do
			if isDisturbed(object) then return true end
		end
		return false
	end

	local function payloadFor(tracker, salt)
		tracker.NextContactId += 1
		tracker.CreatedAt[salt] = tracker.CreatedAt[salt] or clock()
		return {
			ContactId = tracker.NextContactId,
			Salt = salt,
			Hunting = Ghost:GetAttribute("Hunting") == true,
			Time = clock(),
			SaltCreatedAt = tracker.CreatedAt[salt],
		}
	end

	function Tracker:Report(part)
		local salt = saltObject(part)
		if self.Touched[salt] then return end
		self.Touched[salt] = true
		self.PendingSpatial[salt] = nil
		local payload = payloadFor(self, salt)
		Traffic("SaltHit", payload):SendTo("SaltStateAfterHit", "SpeedTracker")
	end

	function Tracker:ReportDisturbed(object)
		local salt = saltObject(object)
		if self.Disturbed[salt] then return end
		self.Disturbed[salt] = true
		self.PendingSpatial[salt] = nil
		local payload = payloadFor(self, salt)
		Traffic("SaltHit", payload):SendTo("SpeedTracker")
		Traffic("SaltStateAfterHit", {
			ContactId = payload.ContactId,
			Salt = salt,
			HuntingAtHit = payload.Hunting,
			State = "disturbed",
			ObservedFor = 0,
			GraceComplete = false,
		}):SendTo("SpeedTracker", "Wraith")
	end

	function Tracker:Watch(object)
		local salt = saltObject(object)
		self.CreatedAt[salt] = self.CreatedAt[salt] or clock()
		if self.Watched[object] then return end
		self.Watched[object] = true
		table.insert(self.Connections, object:GetPropertyChangedSignal("Name"):Connect(function()
			if self.Running and isDisturbed(object) then self:ReportDisturbed(object) end
		end))
		table.insert(self.Connections, object:GetAttributeChangedSignal("Disturbed"):Connect(function()
			if self.Running and isDisturbed(object) then self:ReportDisturbed(object) end
		end))
	end

	function Tracker:Bind(part)
		self:Watch(part)
		if not part:IsA("BasePart") or self.Bound[part] then return end
		if hasDisturbed(saltObject(part)) then
			self:ReportDisturbed(part)
			return
		end
		self.Bound[part] = true
		local salt = saltObject(part)
		self.PendingSpatial[salt] = self.PendingSpatial[salt] or part
		table.insert(self.Connections, part.Touched:Connect(function(hit)
			if self.Running and hit and hit:IsDescendantOf(Ghost) then
				self:Report(part)
			end
		end))
	end

	local queryGhost = dependencies.QueryGhostOverlap
	if not queryGhost then
		local overlap = (dependencies.NewOverlapParams or OverlapParams.new)()
		overlap.FilterType = dependencies.IncludeFilterType or Enum.RaycastFilterType.Include
		overlap.FilterDescendantsInstances = {Ghost}
		overlap.MaxParts = 1
		queryGhost = function(salt, part)
			local cframe, size = part.CFrame, part.Size
			if salt:IsA("Model") then cframe, size = salt:GetBoundingBox() end
			return #World:GetPartBoundsInBox(
				cframe,
				size + Vector3.new(0.6, 1, 0.6),
				overlap
			) > 0
		end
	end

	local function replacementPart(salt)
		if salt:IsA("BasePart") then return salt end
		for _, object in ipairs(salt:GetDescendants()) do
			if object:IsA("BasePart") then return object end
		end
		return nil
	end

	local elapsed = 0
	table.insert(Tracker.Connections, RunService.Heartbeat:Connect(function(deltaTime)
		if not Tracker.Running then return end
		elapsed += deltaTime
		if elapsed < 0.1 then return end
		elapsed = 0
		for salt, part in pairs(Tracker.PendingSpatial) do
			if not salt.Parent or Tracker.Touched[salt] or Tracker.Disturbed[salt] then
				Tracker.PendingSpatial[salt] = nil
			else
				if not part.Parent then
					part = replacementPart(salt)
					Tracker.PendingSpatial[salt] = part
				end
				if part and queryGhost(salt, part) then Tracker:Report(part) end
			end
		end
	end))

	for _, object in ipairs(SaltFolder:GetDescendants()) do Tracker:Bind(object) end
	table.insert(Tracker.Connections, SaltFolder.DescendantAdded:Connect(function(object)
		Tracker:Watch(object)
		local salt = saltObject(object)
		if isDisturbed(object) or hasDisturbed(salt) then
			Tracker:ReportDisturbed(object)
		else
			Tracker:Bind(object)
		end
	end))

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		for _, connection in ipairs(self.Connections) do connection:Disconnect() end
		table.clear(self.Connections)
		table.clear(self.CreatedAt)
	end

	return Tracker
end
]],
	["ghost/active-trackers/speed-tracker.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "speed-tracker requires Traffic")
	local Ghost = assert(dependencies.Ghost, "speed-tracker requires Ghost")
	local clock = dependencies.Clock or os.clock
	local killMatchWindow = tonumber(dependencies.KillMatchWindow) or 0.75
	local Tracker = {
		Kind = "active", Running = true,
		hunting = nil, samples = {}, sampleMeta = {}, displayIndex = 0,
		pendingSalts = {},
	}

	local function sample(source)
		local humanoid = Ghost:FindFirstChildOfClass("Humanoid")
		local speed = humanoid and tonumber(humanoid.WalkSpeed)
		if not speed then return end
		local transparency = Ghost:GetAttribute("Transparency")
		local visible = type(transparency) == "boolean"
			and not transparency
			or type(transparency) == "number" and transparency < 0.5
		local point = {s = speed, v = visible == true}
		table.insert(Tracker.samples, point)
		table.insert(Tracker.sampleMeta, {source = source, time = clock()})
		if Tracker.afterSalt then table.insert(Tracker.afterSalt, point) end
		if Tracker.afterKill then table.insert(Tracker.afterKill, point) end
		return point
	end

	local function sendSalt(completed)
		if not Tracker.beforeSalt or not Tracker.saltState then return end
		Traffic("SaltSpeed", {
			saltState = Tracker.saltState,
			beforeSalt = Tracker.beforeSalt,
			afterSalt = Tracker.afterSalt,
			completed = completed == true,
		}):SendTo("Aswang")
	end

	local function finishSalt()
		if not Tracker.beforeSalt then return end
		if Tracker.saltState then
			sendSalt(true)
		elseif Tracker.contact then
			Tracker.pendingSalts[Tracker.contact] = {
				beforeSalt = Tracker.beforeSalt,
				afterSalt = Tracker.afterSalt,
			}
		end
		Tracker.beforeSalt, Tracker.afterSalt = nil, nil
		Tracker.contact, Tracker.saltState = nil, nil
	end

	local function sendKill(completed)
		if not Tracker.beforeKill then return end
		Traffic("KillSpeed", {
			userId = Tracker.killUserId,
			baselineKill = Tracker.killBaseline,
			beforeKill = Tracker.beforeKill,
			afterKill = Tracker.afterKill,
			completed = completed == true,
		}):SendTo("Aswang", "Keres")
	end

	local function hunting(value)
		if Tracker.hunting == value then return end
		if Tracker.hunting then
			finishSalt()
			sendKill(true)
			Traffic("HuntSpeedEnded", {Count = Tracker.displayIndex}):SendTo("SpeedArrayLog")
		end
		Tracker.hunting, Tracker.samples, Tracker.sampleMeta = value, {}, {}
		Tracker.displayIndex = 0
		Tracker.beforeSalt, Tracker.afterSalt, Tracker.contact, Tracker.saltState = nil, nil, nil, nil
		Tracker.beforeKill, Tracker.afterKill = nil, nil
		Tracker.killUserId, Tracker.killBaseline = nil, nil
		if value then Traffic("HuntSpeedReset", {}):SendTo("SpeedArrayLog") end
		sample("state") -- once while non-hunting; hunt samples continue on visibility changes
	end

	Tracker.Disconnect = Traffic:Receive("SpeedTracker", function(signal, payload)
		payload = type(payload) == "table" and payload or {}
		if signal == "HuntingState" then
			hunting(payload.Hunting == true)
		elseif signal == "HuntSpeedSample" then
			Tracker.displayIndex = tonumber(payload.Index) or Tracker.displayIndex
		elseif signal == "SaltHit" and Tracker.hunting then
			local transition = sample("salt")
			if not transition then return end
			local previousSection = Tracker.afterSalt
				and table.clone(Tracker.afterSalt)
			finishSalt()
			Tracker.contact = payload.ContactId
			-- The first contact compares against the hunt so far. Every later
			-- contact compares against only the samples collected since the prior
			-- contact, while sharing the new transition sample between sections.
			Tracker.beforeSalt = previousSection or table.clone(Tracker.samples)
			Tracker.afterSalt = {transition}
			Traffic("HuntSpeedMarker", {
				Index = Tracker.displayIndex,
				Label = "SALT SPLIT",
			}):SendTo("SpeedArrayLog")
		elseif signal == "SaltStateAfterHit" then
			if payload.ContactId == Tracker.contact then
				Tracker.saltState = payload.State
				sendSalt(false)
			elseif Tracker.pendingSalts[payload.ContactId] then
				local pending = Tracker.pendingSalts[payload.ContactId]
				Traffic("SaltSpeed", {
					saltState = payload.State,
					beforeSalt = pending.beforeSalt,
					afterSalt = pending.afterSalt,
					completed = true,
				}):SendTo("Aswang")
				Tracker.pendingSalts[payload.ContactId] = nil
			end
		elseif signal == "PlayerKilled" and Tracker.hunting then
			local transition = sample("kill")
			if not transition then return end
			sendKill(true)
			Tracker.killUserId = payload.userId
			local splitIndex = #Tracker.samples
			local killTime = tonumber(payload.Time) or clock()
			for index = #Tracker.sampleMeta - 1, 1, -1 do
				local meta = Tracker.sampleMeta[index]
				local age = killTime - meta.time
				if age > killMatchWindow then break end
				if age >= 0 and meta.source == "speed" then
					splitIndex = index
					break
				end
			end
			local splitPoint = Tracker.samples[splitIndex]
			Tracker.killBaseline = splitPoint
			for index = splitIndex - 1, 1, -1 do
				local point = Tracker.samples[index]
				if point.v == splitPoint.v then
					Tracker.killBaseline = point
					break
				end
			end
			Tracker.beforeKill, Tracker.afterKill = {}, {}
			for index = 1, splitIndex do table.insert(Tracker.beforeKill, Tracker.samples[index]) end
			for index = splitIndex, #Tracker.samples do table.insert(Tracker.afterKill, Tracker.samples[index]) end
			Traffic("HuntSpeedMarker", {
				Index = Tracker.displayIndex,
				Label = "KILL",
			}):SendTo("SpeedArrayLog")
		end
	end)

	Tracker.VisibilityConnection = Ghost:GetAttributeChangedSignal("Transparency"):Connect(function()
		if Tracker.hunting then
			sample("visibility")
			sendSalt(false)
			sendKill(false)
		end
	end)
	local humanoid = Ghost:FindFirstChildOfClass("Humanoid")
	if humanoid then
		Tracker.SpeedConnection = humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
			if Tracker.hunting then
				sample("speed")
				sendSalt(false)
				sendKill(false)
			end
		end)
	end
	hunting(Ghost:GetAttribute("Hunting") == true)

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		self.Disconnect()
		self.VisibilityConnection:Disconnect()
		if self.SpeedConnection then self.SpeedConnection:Disconnect() end
		table.clear(self.pendingSalts)
	end

	return Tracker
end
]],
	["ghost/discardable-trackers/catch-fire.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "catch-fire requires Traffic")
	local Ghost = assert(dependencies.Ghost, "catch-fire requires Ghost")
	local delay = dependencies.DelayTask or task and task.delay
	assert(type(delay) == "function", "catch-fire requires task.delay")
	local probeSeconds = tonumber(dependencies.ProbeSeconds) or 0.5
	local Tracker = {Kind = "discardable", Running = true, Connections = {}}

	local function isFire(object)
		return object.Name == "Fire" and object:IsA("ParticleEmitter")
	end

	local function hasFire()
		for _, object in ipairs(Ghost:GetDescendants()) do
			if isFire(object) then return true end
		end
		return false
	end

	local function stop(result)
		if not Tracker.Running then return end
		Tracker.Running = false
		Tracker.Result = result
		Tracker.Disconnect()
		for _, connection in ipairs(Tracker.Connections) do connection:Disconnect() end
		table.clear(Tracker.Connections)
	end

	local function finish(caughtFire, payload)
		if not Tracker.Running then return end
		stop(caughtFire)
		Traffic("HolyOilFireResult", {
			HolyOil = payload.HolyOil,
			CaughtFire = caughtFire,
		}):SendTo("Wisp", "Skinwalker")
	end

	local function probe(payload)
		if Tracker.Pending then return end
		Tracker.Pending = true
		if hasFire() then finish(true, payload) return end
		table.insert(Tracker.Connections, Ghost.DescendantAdded:Connect(function(object)
			if Tracker.Running and isFire(object) then finish(true, payload) end
		end))
		delay(probeSeconds, function()
			if Tracker.Running then finish(hasFire(), payload) end
		end)
	end

	Tracker.Disconnect = Traffic:Receive("CatchFire", function(signal, payload)
		if signal == "WispCollisionConfirmed" then
			stop("unneeded")
		elseif signal == "HolyOilPassed" and type(payload) == "table"
			and payload.Passed == true then
			probe(payload)
		end
	end)

	function Tracker:Destroy() stop("destroyed") end
	return Tracker
end
]],
	["ghost/discardable-trackers/cross-animation.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "cross-animation requires Traffic")
	local RunService = assert(dependencies.RunService, "cross-animation requires RunService")
	local clock = dependencies.Clock or os.clock
	local Tracker = {
		Kind = "discardable",
		Running = true,
		Active = setmetatable({}, {__mode = "k"}),
		ActiveCount = 0,
	}
	local step

	local function stopHeartbeat()
		if not Tracker.Connection then return end
		Tracker.Connection:Disconnect()
		Tracker.Connection = nil
	end

	local function findPart(cross)
		local part = cross and cross:FindFirstChild("Cross", true)
		return part and part:IsA("BasePart") and part or nil
	end

	local function finish(cross, animated)
		if not Tracker.Active[cross] then return end
		Tracker.Active[cross] = nil
		Tracker.ActiveCount -= 1
		Traffic("CrossAnimation", {
			Cross = cross,
			Animated = animated,
		}):SendTo("Demon")
		if Tracker.ActiveCount == 0 then stopHeartbeat() end
	end

	local function startHeartbeat()
		if not Tracker.Connection then
			Tracker.Connection = RunService.Heartbeat:Connect(step)
		end
	end

	Tracker.DisconnectTraffic = Traffic:Receive("CrossAnimation", function(signal, payload)
		if signal ~= "CrossBurn" or not payload or payload.EquipDisabled ~= true then return end
		local cross, part = payload.Cross, findPart(payload.Cross)
		if not cross or not part or Tracker.Active[cross] then return end
		Tracker.Active[cross] = {
			Part = part,
			Started = clock(),
			StartPosition = part.Position,
			LastCFrame = part.CFrame,
			Angle = 0,
			Rise = 0,
			HorizontalSquared = 0,
		}
		Tracker.ActiveCount += 1
		startHeartbeat()
	end)

	step = function()
		if not Tracker.Running then return end
		local now = clock()
		for cross, observation in pairs(Tracker.Active) do
			local part = observation.Part
			if not cross.Parent or not part.Parent then
				finish(cross, false)
			else
				local current = part.CFrame
				local relative = observation.LastCFrame.Rotation:ToObjectSpace(current.Rotation)
				local _, angle = relative:ToAxisAngle()
				angle = math.abs(angle)
				if angle <= math.rad(100) then observation.Angle += angle end
				local dx = current.Position.X - observation.StartPosition.X
				local dy = current.Position.Y - observation.StartPosition.Y
				local dz = current.Position.Z - observation.StartPosition.Z
				observation.Rise = math.max(observation.Rise, dy)
				observation.HorizontalSquared = math.max(
					observation.HorizontalSquared,
					dx * dx + dz * dz
				)
				observation.LastCFrame = current
				local animated = observation.Rise >= 0.45
					and observation.Angle >= math.rad(45)
					and observation.HorizontalSquared <= 25
				if animated then
					finish(cross, true)
				elseif now - observation.Started >= 4 then
					finish(cross, false)
				end
			end
		end
	end

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		self.DisconnectTraffic()
		stopHeartbeat()
		table.clear(self.Active)
	end

	return Tracker
end
]],
	["ghost/discardable-trackers/footstep-sound.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "footstep-sound requires Traffic")
	local Ghost = assert(dependencies.Ghost, "footstep-sound requires Ghost")
	local root = Ghost:FindFirstChild("HumanoidRootPart")
	local Tracker = {Kind = "discardable", Running = false}
	if not root then
		function Tracker:Destroy() end
		return Tracker
	end

	local otherSound
	for _, child in ipairs(root:GetChildren()) do
		if child:IsA("Sound") and child.Name ~= "Hunting" then
			otherSound = child
			break
		end
	end
	Tracker.HasOtherSound = otherSound ~= nil
	Traffic("FootstepSound", {
		HasOtherSound = Tracker.HasOtherSound,
		Sound = otherSound,
	}):SendTo("Umbra")

	function Tracker:Destroy() end
	return Tracker
end
