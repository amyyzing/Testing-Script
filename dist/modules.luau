	["ghost/dormant-trackers/item-orbit.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "item-orbit requires Traffic")
	local World = dependencies.Workspace or workspace
	local Ghost = assert(dependencies.Ghost, "item-orbit requires Ghost")
	local RunService = assert(dependencies.RunService, "item-orbit requires RunService")
	local clock = dependencies.Clock or os.clock
	local interval = tonumber(dependencies.SampleInterval) or 0.1
	local scanRadius = tonumber(dependencies.ScanRadius) or 45
	local minimumRadius = tonumber(dependencies.MinimumRadius) or 2.5
	local maximumRadius = tonumber(dependencies.MaximumRadius) or 40
	local radiusTolerance = tonumber(dependencies.RadiusTolerance) or 0.18
	local minimumDuration = tonumber(dependencies.MinimumDuration) or 0.5
	local minimumSteps = tonumber(dependencies.MinimumSteps) or 5
	local minimumRotation = tonumber(dependencies.MinimumRotation) or math.rad(60)
	local minimumAngleStep = tonumber(dependencies.MinimumAngleStep) or math.rad(0.5)
	local maximumAngleStep = tonumber(dependencies.MaximumAngleStep) or math.rad(100)
	local activeWindow = tonumber(dependencies.ActiveWindow) or 0.3
	local requiredObjects = tonumber(dependencies.RequiredObjects) or 3
	local Tracker = {
		Kind = "dormant",
		Running = true,
		Active = false,
		Reported = false,
		Accumulator = 0,
		Objects = setmetatable({}, {__mode = "k"}),
		States = setmetatable({}, {__mode = "k"}),
		Representatives = setmetatable({}, {__mode = "k"}),
		Containers = setmetatable({}, {__mode = "k"}),
		Connections = {},
	}

	local function distance(first, second)
		local x, y, z = first.X - second.X, first.Y - second.Y, first.Z - second.Z
		return math.sqrt(x * x + y * y + z * z)
	end

	local function ghostPosition()
		if Ghost:IsA("BasePart") then return Ghost.Position end
		return Ghost:GetPivot().Position
	end

	local function usablePart(part)
		return part and part:IsA("BasePart") and part.Anchored ~= true
			and (tonumber(part.Transparency) or 0) < 1
	end

	local function resolveObject(object)
		local part = Tracker.Representatives[object]
		if part and (not part.Parent or not usablePart(part)) then part = nil end
		if not part then
			if usablePart(object) then
				part = object
			elseif object:IsA("Model") then
				part = usablePart(object.PrimaryPart) and object.PrimaryPart or nil
				if not part then
					for _, descendant in ipairs(object:GetDescendants()) do
						if usablePart(descendant) then part = descendant break end
					end
				end
			end
			Tracker.Representatives[object] = part
		end
		return part and part.Position or nil, part and (part.AssemblyRootPart or part) or nil
	end

	local function resetState(object, current, assembly, center, now)
		local x, z = current.X - center.X, current.Z - center.Z
		local radius = math.sqrt(x * x + z * z)
		Tracker.States[object] = {
			X = x,
			Z = z,
			Angle = math.atan2(z, x),
			Radius = radius,
			MinRadius = radius,
			MaxRadius = radius,
			Time = now,
			Direction = 0,
			Rotation = 0,
			Steps = 0,
			Assembly = assembly,
		}
	end

	local function observe(object, current, assembly, center, now)
		local state = Tracker.States[object]
		if not state then
			resetState(object, current, assembly, center, now)
			return
		end
		local x, z = current.X - center.X, current.Z - center.Z
		local radius = math.sqrt(x * x + z * z)
		local angle = math.atan2(z, x)
		local elapsed = now - state.Time
		local delta = math.atan2(math.sin(angle - state.Angle), math.cos(angle - state.Angle))
		local direction = delta >= 0 and 1 or -1
		local minimum = math.min(state.MinRadius, radius)
		local maximum = math.max(state.MaxRadius, radius)
		local meanRadius = (minimum + maximum) * 0.5
		local variation = (maximum - minimum) / math.max(meanRadius, 0.001)
		local invalid = elapsed <= 0 or elapsed > interval * 2.5
			or radius < minimumRadius or radius > maximumRadius
			or variation > radiusTolerance
			or math.abs(delta) > maximumAngleStep
			or state.Direction ~= 0 and math.abs(delta) >= minimumAngleStep
				and direction ~= state.Direction
		if invalid then
			resetState(object, current, assembly, center, now)
			return
		end
		state.X, state.Z, state.Angle, state.Radius = x, z, angle, radius
		state.MinRadius, state.MaxRadius, state.Time = minimum, maximum, now
		state.Assembly = assembly
		if math.abs(delta) < minimumAngleStep then return end
		state.Direction = direction
		state.Rotation += math.abs(delta)
		state.Steps += 1
		state.StartedAt = state.StartedAt or now - elapsed
		state.LastProgress = now
		state.Duration = now - state.StartedAt
		state.RadiusVariation = variation
		state.Qualified = state.Duration >= minimumDuration
			and state.Steps >= minimumSteps
			and state.Rotation >= minimumRotation
	end

	function Tracker:Track(object)
		if object:IsA("Model") or object:IsA("BasePart") then self.Objects[object] = true end
	end

	function Tracker:BindContainer(container)
		if self.Containers[container] then return end
		self.Containers[container] = true
		for _, object in ipairs(container:GetChildren()) do self:Track(object) end
		table.insert(self.Connections, container.ChildAdded:Connect(function(object)
			self:Track(object)
		end))
		table.insert(self.Connections, container.ChildRemoved:Connect(function(object)
			self.Objects[object] = nil
			self.States[object] = nil
			self.Representatives[object] = nil
		end))
	end

	function Tracker:Sample()
		if not self.Active or self.Reported then return end
		local center = ghostPosition()
		local now = clock()
		if self.LastCenter and self.LastSampleAt and now - self.LastSampleAt <= interval * 2
			and distance(center, self.LastCenter) > 8 then
			table.clear(self.States)
		end
		self.LastCenter, self.LastSampleAt = center, now
		for object in pairs(self.Objects) do
			local current, assembly = resolveObject(object)
			if not current or not assembly or distance(current, center) > scanRadius then
				self.States[object] = nil
			else
				observe(object, current, assembly, center, now)
			end
		end

		local matches = {[1] = {}, [-1] = {}}
		local assemblies = {[1] = {}, [-1] = {}}
		for object, state in pairs(self.States) do
			if state.Qualified and state.LastProgress
				and now - state.LastProgress <= activeWindow
				and not assemblies[state.Direction][state.Assembly] then
				assemblies[state.Direction][state.Assembly] = true
				table.insert(matches[state.Direction], {Object = object, State = state})
			end
		end
		local matching = #matches[1] >= requiredObjects and matches[1]
			or #matches[-1] >= requiredObjects and matches[-1]
		if not matching then return end
		local objects = {}
		local duration, steps, rotation = math.huge, math.huge, math.huge
		local maximumVariation = 0
		for _, result in ipairs(matching) do
			table.insert(objects, result.Object)
			duration = math.min(duration, result.State.Duration)
			steps = math.min(steps, result.State.Steps)
			rotation = math.min(rotation, result.State.Rotation)
			maximumVariation = math.max(maximumVariation, result.State.RadiusVariation)
		end
		self.Reported = true
		Traffic("ItemOrbit", {
			Objects = objects,
			Count = #objects,
			Duration = duration,
			Steps = steps,
			Rotation = rotation,
			MaximumRadiusVariation = maximumVariation,
			Direction = matching[1].State.Direction,
			Mode = "NearPerfect",
			Time = now,
		}):SendTo("Ravager")
	end

	local function stopSampling()
		if not Tracker.SampleConnection then return end
		Tracker.SampleConnection:Disconnect()
		Tracker.SampleConnection = nil
	end

	local function setHunting(hunting)
		stopSampling()
		Tracker.Active = hunting == true
		Tracker.Reported = false
		Tracker.Accumulator = 0
		Tracker.LastCenter, Tracker.LastSampleAt = nil, nil
		table.clear(Tracker.States)
		if not Tracker.Active then return end
		Tracker.SampleConnection = RunService.Heartbeat:Connect(function(deltaTime)
			if not Tracker.Running then return end
			Tracker.Accumulator += math.max(0, tonumber(deltaTime) or 0)
			if Tracker.Accumulator < interval then return end
			Tracker.Accumulator %= interval
			Tracker:Sample()
		end)
	end

	local function findContainers(parent)
		if not parent then return end
		for _, name in ipairs({"Items", "Interactables"}) do
			local container = parent:FindFirstChild(name)
			if container then Tracker:BindContainer(container) end
		end
	end
	findContainers(World)
	findContainers(World:FindFirstChild("Map"))
	local added = World.DescendantAdded or World.ChildAdded
	if added then
		table.insert(Tracker.Connections, added:Connect(function(container)
			if container.Name == "Items" or container.Name == "Interactables" then
				Tracker:BindContainer(container)
			end
		end))
	end
	Tracker.Disconnect = Traffic:Receive("ItemOrbit", function(signal, payload)
		if signal == "HuntingState" then
			setHunting(type(payload) == "table" and payload.Hunting == true)
		end
	end)

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		self.Disconnect()
		stopSampling()
		for _, connection in ipairs(self.Connections) do connection:Disconnect() end
		table.clear(self.Connections)
		table.clear(self.Objects)
		table.clear(self.States)
		table.clear(self.Representatives)
	end

	return Tracker
end
]],
	["ghost/dormant-trackers/los-sight.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "los-sight requires Traffic")
	local World = dependencies.Workspace or workspace
	local Ghost = assert(dependencies.Ghost, "los-sight requires Ghost")
	local Players = dependencies.Players or game:GetService("Players")
	local RunService = assert(dependencies.RunService, "los-sight requires RunService")
	local clock = dependencies.Clock or os.clock
	local interval = tonumber(dependencies.SampleInterval) or 0.1
	local maximumDistance = tonumber(dependencies.MaximumDistance) or 120
	local customLOS = dependencies.HasLineOfSight
	local Tracker = {
		Kind = "dormant",
		Running = true,
		Active = false,
		Accumulator = 0,
		Visible = setmetatable({}, {__mode = "k"}),
	}

	local raycastParams
	local function hasLineOfSight(player)
		if customLOS then return customLOS(player) == true end
		local character = player.Character
		local playerRoot = character and character:FindFirstChild("HumanoidRootPart")
		local ghostRoot = Ghost:FindFirstChild("HumanoidRootPart")
			or Ghost.PrimaryPart or Ghost:FindFirstChildWhichIsA("BasePart", true)
		if not playerRoot or not ghostRoot then return false end
		local direction = playerRoot.Position - ghostRoot.Position
		if direction.Magnitude > maximumDistance then return false end
		if not raycastParams then
			raycastParams = RaycastParams.new()
			raycastParams.FilterType = Enum.RaycastFilterType.Exclude
			raycastParams.FilterDescendantsInstances = {Ghost}
			raycastParams.IgnoreWater = true
		end
		local result = World:Raycast(ghostRoot.Position, direction, raycastParams)
		return result == nil or result.Instance:IsDescendantOf(character)
	end

	local function publish(player, visible)
		Traffic("PlayerLineOfSight", {
			Player = player,
			LineOfSight = visible,
			Time = clock(),
		}):SendTo("PlayerSpeed")
	end

	function Tracker:Sample()
		if not self.Active then return end
		local seen = {}
		for _, player in ipairs(Players:GetPlayers()) do
			seen[player] = true
			local visible = player:GetAttribute("Dead") ~= true and hasLineOfSight(player)
			if visible then
				self.Visible[player] = true
				publish(player, true)
			elseif self.Visible[player] then
				self.Visible[player] = nil
				publish(player, false)
			end
		end
		for player in pairs(self.Visible) do
			if not seen[player] then
				self.Visible[player] = nil
				publish(player, false)
			end
		end
	end

	local function stopSampling()
		if not Tracker.SampleConnection then return end
		Tracker.SampleConnection:Disconnect()
		Tracker.SampleConnection = nil
	end

	local function setActive(active)
		if Tracker.Active == active then return end
		Tracker.Active = active
		Tracker.Accumulator = 0
		if not active then
			stopSampling()
			for player in pairs(Tracker.Visible) do publish(player, false) end
			table.clear(Tracker.Visible)
			return
		end
		Tracker.SampleConnection = RunService.Heartbeat:Connect(function(deltaTime)
			if not Tracker.Running then return end
			Tracker.Accumulator += math.max(0, tonumber(deltaTime) or 0)
			if Tracker.Accumulator < interval then return end
			Tracker.Accumulator %= interval
			Tracker:Sample()
		end)
		Tracker:Sample()
	end

	Tracker.Disconnect = Traffic:Receive("LOSSight", function(signal, payload)
		if signal == "HuntingState" then
			setActive(type(payload) == "table" and payload.Hunting == true)
		end
	end)

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		self.Disconnect()
		setActive(false)
	end

	return Tracker
end
]],
	["ghost/dormant-trackers/los-speed.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "los-speed requires Traffic")
	local epsilon = tonumber(dependencies.SpeedEpsilon) or 0.01
	local requiredExposure = tonumber(dependencies.RequiredExposure) or 4
	local Tracker = {Kind = "dormant", Running = true, Resolved = false}

	Tracker.Disconnect = Traffic:Receive("LOSSpeed", function(signal, payload)
		if not Tracker.Running or Tracker.Resolved or signal ~= "PlayerLOSSpeed"
			or type(payload) ~= "table" then return end
		local after = payload.afterLOS or {}
		local base = tonumber(payload.BaseSpeed)
		local sprint = tonumber(payload.SprintSpeed) or (base and base * 1.6)
		if payload.Hunting ~= true or not base or not sprint then return end
		local function near(first, second)
			return math.abs(first - second) <= epsilon
		end
		local compared, slowed, unknown = 0, false, false
		local observed
		for _, point in ipairs(after) do
			local speed = tonumber(point.s)
			if speed then
				compared += 1
				if near(speed, base * 0.8) or near(speed, sprint * 0.8) then
					slowed, observed = true, speed
					break
				elseif not near(speed, base) and not near(speed, sprint) then
					unknown = true
				end
			end
		end
		local duration = tonumber(payload.Duration) or 0
		local ruleOut = duration >= requiredExposure and compared > 0 and not unknown
		if not slowed and not ruleOut then return end
		Tracker.Resolved = true
		Traffic("LOSSpeedResult", {
			Player = payload.Player,
			Slowed = slowed,
			ObservedSpeed = observed,
			BaseSpeed = base,
			SprintSpeed = sprint,
			Completed = slowed or ruleOut,
			Duration = duration,
		}):SendTo("Siren")
	end)

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		self.Disconnect()
	end

	return Tracker
end
]],
	["ghost/dormant-trackers/room-temperature.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "room-temperature requires Traffic")
	local threshold = tonumber(dependencies.Threshold) or 0.08
	local requiredChanges = tonumber(dependencies.RequiredChanges) or 7
	local readTemperature = dependencies.ReadTemperature
	local Tracker = {
		Kind = "dormant",
		Running = true,
		RoundStarted = false,
		Active = false,
		Resolved = false,
		Changes = {},
	}

	local function disconnectRoom()
		if not Tracker.RoomConnection then return end
		Tracker.RoomConnection:Disconnect()
		Tracker.RoomConnection = nil
	end

	local function temperature(room)
		if readTemperature then return tonumber(readTemperature(room)) end
		return room and tonumber(room:GetAttribute("Temperature")) or nil
	end

	function Tracker:Sample()
		if not self.Active or self.Resolved then return end
		local current = temperature(self.Room)
		if current == nil then
			self.Previous = nil
			return
		end
		if self.Previous ~= nil then
			local decrease = self.Previous - current
			if decrease > 0 then table.insert(self.Changes, decrease) end
		end
		self.Previous = current
		if #self.Changes < requiredChanges then return end

		local sum = 0
		for _, change in ipairs(self.Changes) do sum += change end
		local average = sum / #self.Changes
		Traffic("RoomTemperatureAverage", {
			Room = self.Room,
			RoomName = self.Room and self.Room.Name or nil,
			Changes = table.clone(self.Changes),
			Average = average,
			Threshold = threshold,
			Complete = true,
		}):SendTo("Shadow")
		if average < threshold or average > threshold then
			self.Resolved = true
			self.Active = false
			disconnectRoom()
		else
			table.clear(self.Changes)
		end
	end

	local function activateRoom()
		disconnectRoom()
		Tracker.Active = Tracker.RoundStarted and Tracker.Room ~= nil
		Tracker.Previous = Tracker.Active and temperature(Tracker.Room) or nil
		table.clear(Tracker.Changes)
		if Tracker.Active then
			Tracker.RoomConnection = Tracker.Room:GetAttributeChangedSignal("Temperature"):Connect(function()
				Tracker:Sample()
			end)
		end
	end

	local function setRoom(room)
		if room == Tracker.Room or Tracker.Resolved then return end
		Tracker.Room = room
		activateRoom()
	end

	Tracker.Disconnect = Traffic:Receive("RoomTemperature", function(signal, payload)
		if type(payload) ~= "table" then return end
		if signal == "GhostRoom" then
			setRoom(payload.Room)
		elseif signal == "RoundStarted" and payload.Started == true
			and not Tracker.RoundStarted then
			Tracker.RoundStarted = true
			activateRoom()
		end
	end)

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		self.Active = false
		self.Disconnect()
		disconnectRoom()
	end

	return Tracker
end
]],
	["ghost/dormant-trackers/specter-trial.luau"] = [[return function(dependencies)
	local Traffic = assert(dependencies.Traffic, "specter-trial requires Traffic")
	local Ghost = assert(dependencies.Ghost, "specter-trial requires Ghost")
	local RunService = assert(dependencies.RunService, "specter-trial requires RunService")
	local clock = dependencies.Clock or os.clock
	local readPosition = dependencies.Position
	local readCurrentRoom = dependencies.ReadCurrentRoom
	local sampleInterval = tonumber(dependencies.SampleInterval) or 0.1
	local analysisInterval = tonumber(dependencies.AnalysisInterval) or 0.2
	local settledWindow = tonumber(dependencies.SettledWindow) or 0.8
	local stationaryThreshold = tonumber(dependencies.StationaryThreshold) or 0.22
	local armSeconds = tonumber(dependencies.ArmSeconds) or 5
	local roomSettleSeconds = tonumber(dependencies.RoomChangeSettleSeconds) or 2
	local Tracker = {
		Kind = "dormant",
		Running = true,
		Hunting = Ghost:GetAttribute("Hunting") == true,
		Motion = {},
		Sequence = 0,
		Accumulator = 0,
	}

	local function token(value)
		if value and value.Name then value = value.Name end
		return string.lower(tostring(value or ""):gsub("[^%w]", ""))
	end

	local function sameRoom(first, second)
		local left, right = token(first), token(second)
		return left ~= "" and left == right
	end

	local function position()
		if readPosition then return readPosition(Ghost) end
		if Ghost:IsA("BasePart") then return Ghost.Position end
		return Ghost:GetPivot().Position
	end

	local function distance(first, second)
		local x, y, z = first.X - second.X, first.Y - second.Y, first.Z - second.Z
		return math.sqrt(x * x + y * y + z * z)
	end

	local function currentRoom(refresh)
		if readCurrentRoom then return readCurrentRoom(refresh == true) end
		return Ghost:GetAttribute("CurrentRoom")
	end

	local function favouriteRoom()
		return Ghost:GetAttribute("FavoriteRoom")
			or Ghost:GetAttribute("FavouriteRoom")
	end

	local function clearTrial()
		Tracker.CandidateAt = nil
		Tracker.Armed = false
		Tracker.ActiveTrialId = nil
	end

	local function resetMotion(now)
		table.clear(Tracker.Motion)
		Tracker.LastPosition = position()
		Tracker.LastPositionAt = now
		Tracker.MovementSpeed = 0
	end

	local function measure(now)
		local current = position()
		if Tracker.LastPosition and Tracker.LastPositionAt then
			local elapsed = now - Tracker.LastPositionAt
			if elapsed > 0 then
				Tracker.MovementSpeed = distance(current, Tracker.LastPosition) / elapsed
			end
		end
		Tracker.LastPosition, Tracker.LastPositionAt = current, now
		return Tracker.MovementSpeed or 0
	end

	local function settledSpeed(now, fallback)
		local values = {}
		for _, sample in ipairs(Tracker.Motion) do
			if sample.Time >= now - settledWindow then table.insert(values, sample.Speed) end
		end
		if #values == 0 then return fallback end
		table.sort(values)
		local middle = math.floor((#values + 1) / 2)
		if #values % 2 == 1 then return values[middle] end
		return (values[middle] + values[middle + 1]) * 0.5
	end

	local function emit(outcome, now)
		local trialId = Tracker.ActiveTrialId
		if not trialId then
			Tracker.Sequence += 1
			trialId = "specter-trial:" .. Tracker.Sequence
		end
		Traffic("SpecterTrial", {
			TrialId = trialId,
			Outcome = outcome,
			Qualified = true,
			Completed = true,
			FavouriteRoomUnchanged = true,
			ArmedSeconds = math.max(armSeconds, now - (Tracker.CandidateAt or now)),
			Time = now,
		}):SendTo("Specter")
		if outcome == "Departure" then Tracker.Resolved = true end
	end

	local function analyze(now, measuredSpeed)
		if Tracker.Hunting or Tracker.Resolved then return end
		local favourite = favouriteRoom()
		if token(favourite) == "" then clearTrial() return end
		local room = currentRoom(false)
		local inFavourite = sameRoom(room, favourite)
		local stationary = settledSpeed(now, measuredSpeed) <= stationaryThreshold

		if not Tracker.TrackedFavourite then
			Tracker.TrackedFavourite = favourite
		elseif not sameRoom(Tracker.TrackedFavourite, favourite) then
			Tracker.TrackedFavourite = favourite
			Tracker.RoomChangePause = true
			Tracker.RoomChangeSettledAt = nil
			clearTrial()
		end

		if Tracker.RoomChangePause then
			if inFavourite and stationary then
				Tracker.RoomChangeSettledAt = Tracker.RoomChangeSettledAt or now
				if now - Tracker.RoomChangeSettledAt + 1e-6 >= roomSettleSeconds then
					Tracker.RoomChangePause = false
					Tracker.RoomChangeSettledAt = nil
					Tracker.CandidateAt = now
				end
			else
				Tracker.RoomChangeSettledAt = nil
			end
			return
		end

		if not inFavourite or not stationary then
			if Tracker.Armed then emit("Departure", now) end
			clearTrial()
			return
		end
		Tracker.CandidateAt = Tracker.CandidateAt or now
		if not Tracker.Armed and now - Tracker.CandidateAt + 1e-6 >= armSeconds then
			Tracker.Sequence += 1
			Tracker.ActiveTrialId = "specter-trial:" .. Tracker.Sequence
			Tracker.Armed = true
		end
	end

	local function setHunting(hunting, now)
		if hunting == Tracker.Hunting then return end
		local speed = measure(now)
		if hunting then
			if Tracker.Armed and not Tracker.RoomChangePause then
				local favourite = favouriteRoom()
				if sameRoom(Tracker.TrackedFavourite, favourite) then
					local residence = sameRoom(currentRoom(true), favourite)
						and speed <= stationaryThreshold
					emit(residence and "Residence" or "Departure", now)
				end
			end
			clearTrial()
			Tracker.RoomChangePause = false
			Tracker.RoomChangeSettledAt = nil
		elseif not hunting then
			resetMotion(now)
		end
		Tracker.Hunting = hunting
	end

	resetMotion(clock())
	Tracker.Disconnect = Traffic:Receive("SpecterTrial", function(signal, payload)
		if signal == "HuntingState" and type(payload) == "table" then
			setHunting(payload.Hunting == true, tonumber(payload.Time) or clock())
		end
	end)
	Tracker.Connection = RunService.Heartbeat:Connect(function(deltaTime)
		if not Tracker.Running or Tracker.Resolved then return end
		Tracker.Accumulator += math.max(0, tonumber(deltaTime) or 0)
		if Tracker.Accumulator < sampleInterval then return end
		Tracker.Accumulator %= sampleInterval
		local now = clock()
		local speed = measure(now)
		if Tracker.Hunting then return end
		table.insert(Tracker.Motion, {Time = now, Speed = speed})
		while Tracker.Motion[1] and Tracker.Motion[1].Time < now - 12 do
			table.remove(Tracker.Motion, 1)
		end
		if not Tracker.LastAnalysisAt
			or now - Tracker.LastAnalysisAt + 1e-6 >= analysisInterval then
			Tracker.LastAnalysisAt = now
			analyze(now, speed)
		end
	end)

	function Tracker:Destroy()
		if not self.Running then return end
		self.Running = false
		self.Disconnect()
		self.Connection:Disconnect()
		table.clear(self.Motion)
	end

	return Tracker
end
